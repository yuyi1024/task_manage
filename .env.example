# ── Django ───────────────────────────────────────────
# SECRET_KEY 必須固定（Session 以此簽名，重新產生會讓所有人登出）
# 產生方式：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=your-domain.com,localhost
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# ── Database (MariaDB) ────────────────────────────────
DB_HOST=192.168.x.x
DB_PORT=3306
DB_NAME=task_manage
DB_USER=root
DB_PASSWORD=your-db-password

# ── Gunicorn ─────────────────────────────────────────
GUNICORN_WORKERS=2

# ── Proxy sub-path (雙層 nginx 部署用) ─────────────────
# 若部署在反向代理子路徑下（如 /ncsist），設定此變數
# 留空則為根路徑部署
URL_PREFIX=/task_manage
